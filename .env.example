# Required for the waitlist form on the homepage to actually deliver signups anywhere.
# Easiest path: create a free form at https://formspree.io (or use Getform, Basin, etc.)
# and paste its POST endpoint URL here.
VITE_WAITLIST_ENDPOINT=https://formspree.io/f/your_form_id

# Optional: Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX). Leave blank to skip analytics.
VITE_ANALYTICS_ID=
